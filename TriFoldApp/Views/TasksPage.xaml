<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:TriFoldApp.Models"
             xmlns:viewModels="clr-namespace:TriFoldApp.ViewModels"
             x:Class="TriFoldApp.Views.TasksPage"
             x:DataType="viewModels:TasksViewModel"
             Title="Tasks">
    <RefreshView Command="{Binding RefreshCommand}">
        <VerticalStackLayout Padding="20" Spacing="12">
            <Label Text="Daily Tasks" FontSize="26" FontAttributes="Bold" />
            <Label Text="{Binding PendingCount, StringFormat='Pending: {0}'}" />

            <Frame Padding="12" BorderColor="LightGray">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Add New Task" FontAttributes="Bold" />
                    <Entry Placeholder="Task title" Text="{Binding NewTaskTitle}" />
                    <DatePicker Date="{Binding SelectedDueDate}" />
                    <Button Text="Add Task" Command="{Binding AddTaskCommand}" />
                </VerticalStackLayout>
            </Frame>

            <CollectionView ItemsSource="{Binding Tasks}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:TrackerTaskItem">
                        <Frame Padding="10" Margin="0,0,0,8" BorderColor="LightGray">
                            <HorizontalStackLayout Spacing="12">
                                <CheckBox IsChecked="{Binding IsCompleted}" IsEnabled="False" />
                                <VerticalStackLayout HorizontalOptions="StartAndExpand">
                                    <Label Text="{Binding Title}" FontAttributes="Bold" />
                                    <Label Text="{Binding DueDate, StringFormat='Due {0:MMM d}'}" FontSize="12" />
                                </VerticalStackLayout>
                                <Button Text="Done"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ToggleTaskCommand}"
                                        CommandParameter="{Binding .}" />
                                <Button Text="Delete"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteTaskCommand}"
                                        CommandParameter="{Binding .}" />
                            </HorizontalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </RefreshView>
</ContentPage>
